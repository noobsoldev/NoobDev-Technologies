---
interface Props {
  code: string;
}

const { code } = Astro.props;
const lines = code.split('\n');
---

<div class="relative group code-snippet" data-code={code}>
  <button 
    class="copy-button absolute top-0 right-0 bg-[#2D2D2D] hover:bg-[#3D3D3D] text-gray-400 hover:text-white px-3 py-1 rounded text-xs font-sans opacity-0 group-hover:opacity-100 transition-opacity z-10"
    aria-label="Copy code"
  >
    Copy
  </button>
  <pre class="text-gray-300">
    <code>
      {lines.map((line, i) => (
        <div class="flex">
          <span class="text-gray-500 w-8 inline-block select-none">{i + 1}</span>
          <span class="whitespace-pre">{line}</span>
        </div>
      ))}
    </code>
  </pre>
</div>

<script is:inline>
  document.querySelectorAll('.code-snippet').forEach(container => {
    const button = container.querySelector('.copy-button');
    const code = container.getAttribute('data-code');
    
    button.addEventListener('click', () => {
      navigator.clipboard.writeText(code).then(() => {
        const originalText = button.textContent;
        button.textContent = 'Copied!';
        setTimeout(() => {
          button.textContent = originalText;
        }, 2000);
      });
    });
  });
</script>
