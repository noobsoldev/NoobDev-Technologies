---
import Brace from './Brace.astro';

interface Props {
  faqs: { question: string, answer: string }[];
}

const { faqs } = Astro.props;

// Split FAQs into two columns for desktop
const leftColumn = faqs.slice(0, Math.ceil(faqs.length / 2));
const rightColumn = faqs.slice(Math.ceil(faqs.length / 2));
---

<section class="section-padding bg-white text-black border-t border-gray-100">
  <div class="container-custom">
    <h2 class="mb-20 text-center text-black">Frequently Asked <Brace>Questions</Brace></h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
      {/* Left Column */}
      <div class="space-y-6">
        {leftColumn.map((faq, index) => (
          <div class="faq-item border border-gray-100 bg-gray-50 rounded-2xl overflow-hidden transition-all duration-500 hover:border-[#FF0000]/30 hover:shadow-xl hover:shadow-red-500/5">
            <button 
              class="faq-trigger w-full px-8 py-6 text-left flex items-center justify-between group"
              aria-expanded="false"
            >
              <span class="font-semibold text-gray-700 group-hover:text-black transition-colors text-[15px] md:text-base leading-snug">{faq.question}</span>
              <span class="faq-icon text-[#FF0000] transition-transform duration-500 flex-shrink-0 ml-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </span>
            </button>
            <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
              <div class="px-8 pb-8 text-gray-600 leading-relaxed text-sm">
                {faq.answer}
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Right Column */}
      <div class="space-y-6">
        {rightColumn.map((faq, index) => (
          <div class="faq-item border border-gray-100 bg-gray-50 rounded-2xl overflow-hidden transition-all duration-500 hover:border-[#FF0000]/30 hover:shadow-xl hover:shadow-red-500/5">
            <button 
              class="faq-trigger w-full px-8 py-6 text-left flex items-center justify-between group"
              aria-expanded="false"
            >
              <span class="font-semibold text-gray-700 group-hover:text-black transition-colors text-[15px] md:text-base leading-snug">{faq.question}</span>
              <span class="faq-icon text-[#FF0000] transition-transform duration-500 flex-shrink-0 ml-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </span>
            </button>
            <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
              <div class="px-8 pb-8 text-gray-600 leading-relaxed text-sm">
                {faq.answer}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');
  
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      const content = trigger.nextElementSibling as HTMLElement;
      const icon = trigger.querySelector('.faq-icon');
      
      // Toggle current item
      trigger.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      content.style.maxHeight = !isExpanded ? `${content.scrollHeight}px` : '0';
      icon?.classList.toggle('rotate-180');
    });
  });
</script>

<style>
  .rotate-180 {
    transform: rotate(180deg);
  }
</style>
