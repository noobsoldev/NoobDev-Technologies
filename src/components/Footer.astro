---
import { Logo } from '../react-components/Layout';
import { NewsletterForm } from '../react-components/NewsletterForm';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 pt-32 pb-16">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-24">
      <div class="lg:col-span-1">
        <Logo className="text-2xl mb-4" />
        <div class="space-y-1 mb-8">
          <p class="text-[10px] font-mono text-gray-400 uppercase tracking-[0.2em] font-semibold">No-Code Automation Studio</p>
          <p class="text-[10px] font-mono text-gray-400 uppercase tracking-[0.2em]">estd 2025</p>
        </div>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs">
          Democratizing automation for businesses worldwide. We build the technical foundation your business needs to scale without friction.
        </p>
      </div>

      <div>
        <h3 class="text-[11px] font-mono uppercase tracking-[0.2em] text-black mb-8 font-semibold">Platform</h3>
        <ul class="space-y-4">
          {['Home', 'About', 'Services', 'Showcase', 'Blog'].map((item) => (
            <li>
              <a href={item === 'Home' ? '/' : `/${item.toLowerCase()}`} class="text-gray-500 hover:text-black transition-colors text-sm">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-[11px] font-mono uppercase tracking-[0.2em] text-black mb-8 font-semibold">Initiatives</h3>
        <ul class="space-y-4">
          {['Startup Perks', '100 Business Initiative', 'Contact'].map((item) => (
            <li>
              <a href={item === 'Startup Perks' ? '/perks' : item === '100 Business Initiative' ? '/100-business-initiative' : '/contact'} class="text-gray-500 hover:text-black transition-colors text-sm">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-[11px] font-mono uppercase tracking-[0.2em] text-black mb-8 font-semibold">Connect</h3>
        <div class="flex space-x-6 mb-8">
          <a href="https://x.com/noobdevtech" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#FF0000] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
          <a href="https://instagram.com/noobdevtech" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#FF0000] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.245 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.245-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.245-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.245 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.667.072 4.947c.2 4.337 2.617 6.76 6.98 6.98 1.281.059 1.689.073 4.948.073s3.667-.014 4.947-.072c4.357-.2 6.78-2.618 6.98-6.98.059-1.281.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.2-4.358-2.618-6.78-6.98-6.98-1.281-.059-1.689-.073-4.948-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c.796 0 1.441-.645 1.441-1.44s-.645-1.44-1.441-1.44-1.44.645-1.44 1.44.645 1.44 1.44 1.44z"></path></svg>
          </a>
          <a href="https://wa.me/919810141789" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#FF0000] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
        <div class="max-w-xs">
          <p class="text-[11px] font-mono uppercase tracking-[0.2em] text-black mb-4 font-semibold">Newsletter</p>
          <NewsletterForm client:visible minimal={true} />
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-[11px] font-mono uppercase tracking-widest text-gray-400">
        © {currentYear} NOOBDEV TECHNOLOGIES
      </p>
      <div class="flex gap-6 text-[11px] font-mono uppercase tracking-widest text-gray-400">
        <button data-legal="privacy" class="legal-link hover:text-black transition-colors">Privacy</button>
        <button data-legal="terms" class="legal-link hover:text-black transition-colors">Terms</button>
        <button data-legal="cookies" class="legal-link hover:text-black transition-colors">Cookies</button>
      </div>
      <p class="text-[11px] font-mono uppercase tracking-widest text-gray-400">
        Made with <span class="text-[#FF0000]">{"{❤️}"}</span> for the future
      </p>
    </div>
  </div>
</footer>

<!-- Legal Modal -->
<div id="legal-modal-backdrop" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
  <div id="legal-modal" class="bg-[#1e1e1e] text-[#e5e5e5] w-full max-w-3xl max-h-[85vh] rounded-xl shadow-2xl border border-[#333] flex flex-col transform scale-95 transition-transform duration-300 font-mono text-sm">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-[#333] bg-[#252526] rounded-t-xl shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
        <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
        <span id="legal-modal-title" class="ml-4 text-xs font-semibold tracking-widest uppercase text-gray-400">policy.md</span>
      </div>
      <button id="legal-modal-close" class="text-gray-400 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <!-- Body -->
    <div id="legal-modal-content" class="p-8 overflow-y-auto custom-scrollbar max-w-none">
      <!-- Content injected here -->
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #1e1e1e;
    border-radius: 0 0 8px 0;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #555;
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #777;
  }
  
  #legal-modal-content {
    color: #e5e5e5; /* Light gray for high contrast */
  }
  #legal-modal-content h1 {
    color: #ffffff;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }
  #legal-modal-content h2 {
    color: #ffffff;
    font-size: 1.1rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #444;
    padding-bottom: 0.5rem;
    font-weight: 600;
  }
  #legal-modal-content p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: #d4d4d4;
  }
  #legal-modal-content strong {
    color: #ff5f56;
    font-weight: 600;
  }
  #legal-modal-content a {
    color: #4daafc;
    text-decoration: none;
  }
  #legal-modal-content a:hover {
    text-decoration: underline;
  }
</style>

<script>
  const legalContent = {
    privacy: `
      <h1>Privacy Policy</h1>
      <p style="color: #9ca3af; font-size: 0.75rem; margin-bottom: 2rem;">Last Updated: April 2026</p>
      <h2>1. Information We Collect</h2>
      <p>At Noob{Dev} Technologies, we collect information you provide directly to us when you use our services, fill out a form, or communicate with us. This may include your name, email address, phone number, and project details.</p>
      <h2>2. How We Use Your Information</h2>
      <p>We use the information we collect to provide, maintain, and improve our services, process transactions, send technical notices, and communicate with you about products, services, and events offered by Noob{Dev} Technologies.</p>
      <h2>3. Data Sharing and Security</h2>
      <p>We do not sell your personal data. We may share information with third-party vendors, consultants, and other service providers who need access to such information to carry out work on our behalf. We implement reasonable security measures to protect your data.</p>
      <h2>4. Third-Party Tools</h2>
      <p>Our automation solutions may integrate with third-party platforms (e.g., Zapier, Make, OpenAI). Your data processed through these integrations is subject to their respective privacy policies.</p>
      <h2>5. Contact Us</h2>
      <p>If you have any questions about this Privacy Policy, please contact us at <a href="mailto:hello@noobdev.tech">hello@noobdev.tech</a>.</p>
    `,
    terms: `
      <h1>Terms & Conditions</h1>
      <p style="color: #9ca3af; font-size: 0.75rem; margin-bottom: 2rem;">Last Updated: April 2026</p>
      <h2>1. Service Scope</h2>
      <p>Noob{Dev} Technologies provides web development, no-code automation, and technical consulting services. The specific scope of work, deliverables, and timelines will be outlined in a separate Statement of Work (SOW) or proposal for each client.</p>
      <h2>2. Payment Terms & Refunds</h2>
      <p>Payment schedules are defined in your specific proposal. Generally, we require an upfront deposit before commencing work. <strong>All payments are non-refundable</strong> once work has begun, as our services involve custom intellectual property and dedicated time.</p>
      <h2>3. No Guarantees / Results Disclaimer</h2>
      <p>While we strive to build high-performance systems and efficient automations, we do not guarantee specific business results, sales, or traffic increases. The success of your business depends on various factors beyond our technical implementations.</p>
      <h2>4. Third-Party Tools & Integrations</h2>
      <p>Our solutions often rely on third-party software (e.g., Webflow, Shopify, Zapier, OpenAI). We are not responsible for downtime, API changes, pricing updates, or data breaches caused by these third-party providers.</p>
      <h2>5. User Responsibilities</h2>
      <p>Clients are responsible for providing necessary assets, access credentials, and timely feedback. Delays in client responses may result in project timeline extensions.</p>
      <h2>6. Limitation of Liability</h2>
      <p>To the maximum extent permitted by law, Noob{Dev} Technologies shall not be liable for any indirect, incidental, special, consequential, or punitive damages, or any loss of profits or revenues, whether incurred directly or indirectly, resulting from your use of our services.</p>
    `,
    cookies: `
      <h1>Cookies Policy</h1>
      <p style="color: #9ca3af; font-size: 0.75rem; margin-bottom: 2rem;">Last Updated: April 2026</p>
      <h2>1. What Are Cookies</h2>
      <p>Cookies are small text files stored on your device when you visit our website. They help us understand how you interact with our site and improve your experience.</p>
      <h2>2. How We Use Cookies</h2>
      <p>We use essential cookies to make our website work and analytics cookies to understand site traffic and usage patterns. We do not use intrusive advertising cookies.</p>
      <h2>3. Third-Party Cookies</h2>
      <p>We use trusted third-party analytics tools (like Google Analytics) which may set cookies on your device to track page views, session duration, and user behavior.</p>
      <h2>4. Managing Cookies</h2>
      <p>You can control and/or delete cookies as you wish through your browser settings. However, disabling certain cookies may impact the functionality of our website.</p>
    `
  };

  const backdrop = document.getElementById('legal-modal-backdrop');
  const modal = document.getElementById('legal-modal');
  const content = document.getElementById('legal-modal-content');
  const title = document.getElementById('legal-modal-title');
  const closeBtn = document.getElementById('legal-modal-close');
  const links = document.querySelectorAll('.legal-link');

  function openModal(type) {
    if (!backdrop || !modal || !content || !title) return;
    
    content.innerHTML = legalContent[type];
    title.textContent = type + '.md';
    
    backdrop.classList.remove('hidden');
    // Trigger reflow
    void backdrop.offsetWidth;
    
    backdrop.classList.remove('opacity-0');
    modal.classList.remove('scale-95');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!backdrop || !modal) return;
    
    backdrop.classList.add('opacity-0');
    modal.classList.add('scale-95');
    document.body.style.overflow = '';
    
    setTimeout(() => {
      backdrop.classList.add('hidden');
    }, 300);
  }

  links.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const type = link.getAttribute('data-legal');
      if (type) openModal(type);
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  
  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !backdrop?.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>

