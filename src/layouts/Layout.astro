---
import '../index.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/fira-code/400.css';
import '@fontsource/fira-code/500.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalURL?: string;
  breadcrumb?: { name: string, item: string }[];
  faqs?: { question: string, answer: string }[];
}

const { 
  title = "Noob{Dev} Technologies | Websites & Automation Systems That Help Your Business Grow Faster",
  description = "Noob{Dev} Technologies is a global no-code automation studio. We build high-performance websites and automate business workflows using AI for businesses worldwide.",
  keywords = "web development agency Greater Noida, automation agency India, website for salon India, website for optical store India, no-code automation small business India",
  ogImage = "https://raw.githubusercontent.com/noobsoldev/NoobDev-Technologies-/main/Screenshot%202026-04-12%20050202.png",
  canonicalURL = Astro.url.href,
  breadcrumb = [],
  faqs = []
} = Astro.props;

const defaultBreadcrumbs = [
  { name: "Home", item: "https://noobdev.tech" },
  ...breadcrumb
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords}>
    <meta name="author" content="Noob{Dev} Technologies">
    <meta name="theme-color" content="#FF0000">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:locale" content="en_IN">
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/jpeg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src * data: blob:; connect-src * https://www.google-analytics.com;">
    <title>{title}</title>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <!-- Preload Critical Fonts -->
    <link rel="preload" href="/_astro/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/_astro/inter-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin>

    <!-- Delayed Google Tag Manager -->
    <script is:inline>
      window.addEventListener('load', function() {
        // Use requestIdleCallback for even better performance if available
        const runGTM = function() {
          setTimeout(function() {
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=G-D6CP5JFSYV';
            document.head.appendChild(script);
            
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-D6CP5JFSYV');
          }, 4000); // Increased delay to 4 seconds
        };

        if ('requestIdleCallback' in window) {
          requestIdleCallback(runGTM);
        } else {
          runGTM();
        }
      });
    </script>
    
    <script is:inline>window.process = { env: {} };</script>
    
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Noob{Dev} Technologies",
        "image": "https://raw.githubusercontent.com/noobsoldev/NoobDev-Technologies-/main/Screenshot%202026-04-12%20050202.png",
        "@id": "https://noobdev.tech",
        "url": "https://noobdev.tech",
        "telephone": "+91-9810141789",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Greater Noida",
          "addressLocality": "Greater Noida",
          "addressRegion": "UP",
          "postalCode": "201308",
          "addressCountry": "IN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 28.4744,
          "longitude": 77.5040
        },
        "areaServed": [
          "Noida",
          "Greater Noida",
          "Ghaziabad",
          "Delhi NCR",
          "Gurgaon",
          "Faridabad"
        ],
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "124"
        },
        "review": [
          {
            "@type": "Review",
            "author": "Rajesh Kumar",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5"
            },
            "reviewBody": "Best automation agency in Noida. They saved us 20 hours a week!"
          }
        ],
        "sameAs": [
          "https://linkedin.com/company/noobdev",
          "https://twitter.com/noobdev"
        ]
      }
    </script>
    {faqs.length > 0 && (
      <script type="application/ld+json" is:inline define:vars={{ faqs }}>
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.question,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": faq.answer
            }
          }))
        }
      </script>
    )}
    <script type="application/ld+json" is:inline define:vars={{ defaultBreadcrumbs }}>
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": defaultBreadcrumbs.map((bc, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": bc.name,
          "item": bc.item
        }))
      }
    </script>
</head>
<body class="bg-white text-black font-sans selection:bg-[#FF0000] selection:text-white">
    <Navbar currentPath={Astro.url.pathname} />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>
