---
import '../index.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const { 
  title = "Noob{Dev} Technologies | Web Development & Automation Agency",
  description = "No-code automation and web development agency based in Greater Noida, India. We build websites for salons, optical stores, resorts, and small businesses — and automate their operations using Make.com, Supabase, and AI workflows.",
  ogImage = "https://noobdev.tech/og-image.jpg",
  canonicalURL = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta name="keywords" content="web development agency Greater Noida, automation agency India, website for salon India, website for optical store India, no-code automation small business India">
    <meta name="author" content="Noob{Dev} Technologies">
    <meta name="theme-color" content="#FF0000">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:locale" content="en_IN">
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/jpeg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src * data: blob:; connect-src * https://www.google-analytics.com;">
    <title>{title}</title>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <!-- Optimized Google Fonts Loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Inter:wght@400;500;600&family=Fira+Code:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Inter:wght@400;500;600&family=Fira+Code:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet">
    </noscript>

    <!-- Delayed Google Tag Manager -->
    <script is:inline>
      window.addEventListener('load', function() {
        // Use requestIdleCallback for even better performance if available
        const runGTM = function() {
          setTimeout(function() {
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=G-D6CP5JFSYV';
            document.head.appendChild(script);
            
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-D6CP5JFSYV');
          }, 4000); // Increased delay to 4 seconds
        };

        if ('requestIdleCallback' in window) {
          requestIdleCallback(runGTM);
        } else {
          runGTM();
        }
      });
    </script>
    
    <script is:inline>window.process = { env: {} };</script>
    
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Noob{Dev} Technologies",
        "image": "https://noobdev.tech/og-image.jpg",
        "@id": "https://noobdev.tech",
        "url": "https://noobdev.tech",
        "telephone": "+91-9810141789",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Greater Noida",
          "addressLocality": "Greater Noida",
          "addressRegion": "UP",
          "postalCode": "201308",
          "addressCountry": "IN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 28.4744,
          "longitude": 77.5040
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        },
        "sameAs": [
          "https://linkedin.com/company/noobdev",
          "https://twitter.com/noobdev"
        ]
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://noobdev.tech"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Services",
            "item": "https://noobdev.tech/services"
          }
        ]
      }
    </script>
</head>
<body class="bg-white text-black font-sans selection:bg-[#FF0000] selection:text-white">
    <Navbar currentPath={Astro.url.pathname} />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>
