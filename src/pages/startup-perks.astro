---
import Layout from '../layouts/Layout.astro';
import { StartupPerks } from '../react-pages/StartupPerks';

const title = "Startup Perks & Discounts | NoobDev Technologies Noida";
const description = "Exclusive startup perks, discounts, and credits for NoobDev clients. Save thousands on essential tools like AWS, Stripe, HubSpot, and more to grow your business.";
const keywords = "startup perks, startup discounts Noida, AWS credits for startups, HubSpot discounts, NoobDev startup program";
---
<Layout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumb={[{ name: "Startup Perks", item: "https://noobdev.tech/startup-perks" }]}
>
  <StartupPerks client:visible />
</Layout>
