---
import Layout from '../../layouts/Layout.astro';
import Brace from '../../components/Brace.astro';
import { Blog as BlogPage } from '../../react-pages/Blog';
---

<Layout 
  title="Blog | Noob{Dev} Technologies"
  description="Deep dives into business automation, no-code architecture, and the future of work. Insights from Noob{Dev} Technologies."
>
  <div class="page-transition pt-32 pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      {/* Header Section */}
      <div class="mb-16">
        <div class="flex items-center gap-2 mb-4">
          <div class="h-px w-12 bg-[#FF0000]"></div>
          <span class="font-mono text-xs text-[#FF0000] uppercase tracking-widest">The Terminal Blog</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6">
          <Brace>Insights</Brace> & Updates: No-Code Automation Studio Blog
        </h1>
        <p class="text-xl text-gray-700 max-w-2xl leading-relaxed">
          Deep dives into business automation, no-code architecture, and the future of work.
        </p>
      </div>

      <BlogPage client:load />
    </div>
  </div>
</Layout>

