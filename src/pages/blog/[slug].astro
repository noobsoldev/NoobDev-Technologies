---
import Layout from '../../layouts/Layout.astro';
import { BlogPost } from '../../react-pages/BlogPost';
import { BLOG_POSTS } from '../../constants';

export function getStaticPaths() {
  return BLOG_POSTS.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt,
  "author": {
    "@type": "Organization",
    "name": "Noob{Dev} Technologies"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Noob{Dev} Technologies",
    "logo": {
      "@type": "ImageObject",
      "url": "https://raw.githubusercontent.com/noobsoldev/NoobDev-Technologies-/main/Screenshot%202026-04-12%20050202.png"
    }
  },
  "datePublished": post.date,
  "keywords": post.category
};
---

<Layout 
  title={`${post.title} | NoobDev Technologies Blog`} 
  description={post.excerpt}
  keywords={`${post.category}, automation blog Noida, web development insights Greater Noida`}
  breadcrumb={[
    { name: "Blog", item: "https://noobdev.tech/blog" },
    { name: post.title, item: `https://noobdev.tech/blog/${post.slug}` }
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <BlogPost client:visible />
</Layout>
