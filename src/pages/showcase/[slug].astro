---
import Layout from '../../layouts/Layout.astro';
import { ProjectCaseStudy } from '../../react-pages/ProjectCaseStudy';
import { PROJECTS } from '../../constants';

export function getStaticPaths() {
  return PROJECTS.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const creativeWorkSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": project.title,
  "description": project.description,
  "creator": {
    "@type": "Organization",
    "name": "Noob{Dev} Technologies"
  },
  "keywords": project.tags ? project.tags.join(', ') : ""
};
---

<Layout 
  title={`${project.title} Case Study | NoobDev Technologies Noida`} 
  description={project.description}
  keywords={`${project.title} case study, web development portfolio Noida, automation projects Greater Noida, ${project.tags ? project.tags.join(', ') : ''}`}
  breadcrumb={[
    { name: "Showcase", item: "https://noobdev.tech/showcase" },
    { name: project.title, item: `https://noobdev.tech/showcase/${project.slug}` }
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(creativeWorkSchema)} />
  <ProjectCaseStudy client:visible />
</Layout>
