---
import Layout from '../../layouts/Layout.astro';
import Brace from '../../components/Brace.astro';
import { Showcase } from '../../react-pages/Showcase';
const title = "Our Work & Case Studies | NoobDev Technologies Noida";
const description = "Real results for real businesses. Browse our portfolio of automated success stories, web development projects, and AI integrations by NoobDev Technologies.";
const keywords = "web development portfolio Noida, automation case studies Greater Noida, NoobDev projects, AI automation examples India";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumb={[{ name: "Showcase", item: "https://noobdev.tech/showcase" }]}
>
  <div class="page-transition section-padding">
    <div class="container-custom">
      <div class="mb-24 text-center">
        <h1 class="mb-6"><Brace>Our Work</Brace>: AI Automation & Web Development Projects</h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto mb-8 leading-relaxed">
          Real results for real businesses. Browse our portfolio of automated success stories by Noob{`{Dev}`} Technologies. We specialize in building high-performance digital assets that don't just look good, but actually drive measurable business growth.
        </p>
        <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed text-[15px]">
          From custom healthcare CRMs and headless e-commerce platforms to hyperlocal SEO dominance for service providers, our work spans across diverse industries. Each project is a testament to our commitment to technical excellence and no-code efficiency.
        </p>
      </div>

      <Showcase client:visible />
    </div>
  </div>
</Layout>

