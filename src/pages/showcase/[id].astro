---
import Layout from '../../layouts/Layout.astro';
import { ProjectCaseStudy } from '../../react-pages/ProjectCaseStudy';
import { PROJECTS } from '../../constants';

export function getStaticPaths() {
  return PROJECTS.map(project => ({
    params: { id: project.id.toString() },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} Case Study | Noob{Dev} Technologies`} description={project.description}>
  <ProjectCaseStudy client:load />
</Layout>
