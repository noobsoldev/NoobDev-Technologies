---
import Layout from '../layouts/Layout.astro';
import { Initiative } from '../react-pages/Initiative';

const title = "100 Business Initiative | Free Web Development & Automation Noida";
const description = "Join NoobDev's 100 Business Initiative. We are helping 100 local businesses in Noida and Greater Noida scale with free or heavily discounted web development and automation.";
const keywords = "100 business initiative, free web development Noida, small business automation Greater Noida, NoobDev initiative";
---
<Layout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumb={[{ name: "100 Business Initiative", item: "https://noobdev.tech/100-business-initiative" }]}
>
  <Initiative client:visible />
</Layout>
