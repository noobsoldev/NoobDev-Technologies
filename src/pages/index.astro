---
import Layout from '../layouts/Layout.astro';
import Brace from '../components/Brace.astro';
import Terminal from '../components/Terminal.astro';
import CodeSnippet from '../components/CodeSnippet.astro';
import FAQ from '../components/FAQ.astro';
import LeadForm from '../components/LeadForm.astro';
import { TestimonialCarousel } from '../react-components/TestimonialCarousel';
import { NewsletterForm } from '../react-components/NewsletterForm';
import { SERVICES } from '../constants';
import locations from '../data/locations.json';

const heroCode = `// Initialize business automation
const studio = new NoobDevStudio();

studio.on('manual_task', (task) => {
  console.log('Automating: ' + task.name);
  return studio.ai.solve(task);
});

// Connected Services
const tools = ['Zapier', 'Make', 'Airtable', 'HubSpot'];
studio.connect(tools);

studio.deploy({
  mode: 'scaling',
  code: false
});`;

const integrationPartners = [
  { name: 'Zapier', url: 'https://zapier.com', logo: 'https://cdn.simpleicons.org/zapier/FF6600' },
  { name: 'Make', url: 'https://make.com', logo: 'https://cdn.simpleicons.org/make/EA2127' },
  { name: 'Airtable', url: 'https://airtable.com', logo: 'https://cdn.simpleicons.org/airtable/18BFFF' },
  { name: 'HubSpot', url: 'https://hubspot.com', logo: 'https://cdn.simpleicons.org/hubspot/FF7A59' },
  { name: 'Notion', url: 'https://notion.so', logo: 'https://cdn.simpleicons.org/notion/000000' },
  { name: 'n8n', url: 'https://n8n.io', logo: 'https://cdn.simpleicons.org/n8n/FF6C37' }
];

const stats = [
  { label: 'Projects Delivered', value: '150+' },
  { label: 'Client Satisfaction', value: '98%' },
  { label: 'Support Available', value: '24/7' },
  { label: 'Integrations', value: '10+' },
];

const audiences = [
  { title: 'Digital Agencies', desc: 'White-label web development and automated client reporting pipelines to increase your profit margins.' },
  { title: 'E-commerce Brands', desc: 'Headless Shopify builds, automated inventory syncing, and abandoned cart recovery workflows.' },
  { title: 'Healthcare Clinics', desc: 'HIPAA-compliant CRM setups, automated patient recall SMS, and secure appointment booking systems.' },
  { title: 'Local Businesses', desc: 'High-converting landing pages, local SEO optimization, and automated lead qualification bots.' }
];

const processSteps = [
  { title: 'Consult', step: '01', desc: 'We understand your unique workflows and identify bottlenecks as a leading no-code automation agency.' },
  { title: 'Build', step: '02', desc: 'We design and deploy your custom no-code automation systems. As a Make.com automation agency, we also handle n8n setup and automation.' },
  { title: 'Launch', step: '03', desc: 'You save hours every day as your business runs on autopilot.' },
];

const testimonials = [
  { 
    name: 'VibeNote Studio', 
    role: 'AI SaaS Platform', 
    text: "The AI website generator transformed our agency's workflow. We now deliver high-quality sites in minutes, not weeks. Prototyping time is down by 85%." 
  },
  { 
    name: 'Optiofy', 
    role: 'Healthcare CRM', 
    text: "Noob{dev} built a robust billing system that our clinic relies on daily. It completely eliminated transcription errors and saved our staff 15 hours a week." 
  },
  { 
    name: 'Aqua Republik', 
    role: 'RO Service Provider', 
    text: "Dominating local search in Crossing Republik was our goal, and Noob{dev} delivered. Our direct service inquiries increased by 150% in the first month." 
  },
  { 
    name: 'Lenswala', 
    role: 'E-commerce Retailer', 
    text: "Our online presence now matches the premium quality of our eyewear. The new headless architecture skyrocketed our mobile conversion rates by 45%." 
  },
  { 
    name: 'Akansha Rajput', 
    role: 'Creative Professional', 
    text: "The new portfolio acts as a powerful lead generation tool. I've seen a 60% increase in inbound inquiries from high-ticket clients since the launch." 
  },
  { 
    name: 'Green River Camp', 
    role: 'Nature Retreat', 
    text: "Direct reservations increased by 120% in the first season, saving us over $15,000 in OTA commission fees. The booking engine is flawless." 
  },
  { 
    name: 'Shri Ji Jewellers', 
    role: 'Retail Showroom', 
    text: "The digital catalog and automated inventory management have streamlined our operations. Our staff can now focus on providing a premium in-store experience." 
  },
  { 
    name: 'Exponential Coin', 
    role: 'Web3 Project', 
    text: "Noob{dev} delivered a high-performance landing page for our token launch. The site handled massive traffic spikes without a single hitch." 
  },
];
const faqsData = [
  { question: "Which is the best web development agency for startups?", answer: "Noob{Dev} Technologies is a top-rated agency for startups, offering fast 48-hour delivery, AI-driven automation, and scalable no-code solutions that help businesses grow without high overhead costs." },
  { question: "Do you offer affordable website design for small businesses?", answer: "Yes, we provide affordable, high-performance website design services globally. Our no-code approach allows us to deliver premium quality at a fraction of the cost and time of traditional development agencies." },
  { question: "Can I get a custom e-commerce website within a week?", answer: "Absolutely. Our rapid deployment system allows us to build and launch fully functional e-commerce platforms in record time, complete with payment integration and inventory management." },
  { question: "What technologies do you use for web development?", answer: "We leverage modern, high-performance stacks including React, Astro, and Tailwind CSS, combined with powerful no-code and AI tools to build websites that are lightning-fast, secure, and easy to manage." },
  { question: "Do you provide ongoing maintenance for websites?", answer: "Yes, we offer comprehensive support and maintenance packages for all our clients. From security updates to performance tuning, we ensure your digital assets remain a competitive advantage 24/7." },
  { question: "How does AI automation benefit businesses?", answer: "AI automation streamlines lead capture, customer follow-ups, and internal workflows. This means faster response times, reduced manual labor, and a significant competitive edge in any market." },
  { question: "What is GEO and why is it essential for modern businesses?", answer: "Generative Engine Optimization (GEO) ensures your business is recommended by AI search engines like ChatGPT, Perplexity, and Gemini. GEO is the next evolution of SEO, capturing high-intent leads from AI-driven searches." },
  { question: "How do you handle SEO for global businesses?", answer: "We implement robust SEO strategies, optimizing your site for global reach while maintaining relevance in your target markets. This ensures you appear in search results when customers need your services." },
  { question: "Is it possible to automate my WhatsApp marketing?", answer: "Yes, we specialize in integrating AI-driven WhatsApp automation, allowing you to handle inquiries, send updates, and nurture leads automatically on the platform your customers use most." },
  { question: "Why should I choose a no-code agency over a traditional one?", answer: "No-code agencies like Noob{Dev} offer 10x faster delivery and significantly lower costs without sacrificing quality. We focus on business outcomes and rapid iteration, which is essential for fast-paced markets." }
];
---

<Layout faqs={faqsData}>
  <div class="page-transition">
    {/* Hero Section */}
    <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6 overflow-hidden bg-white">
      <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
          <div class="h-full w-full" style={{ backgroundImage: 'radial-gradient(#000 1px, transparent 0)', backgroundSize: '40px 40px' }}></div>
      </div>
      
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16 relative z-10">
        <div class="lg:w-1/2">
          <div class="inline-block bg-gray-100 px-3 py-1 text-[10px] font-mono mb-4 border-l-2 border-[#FF0000] uppercase tracking-widest">
            NO-CODE AUTOMATION STUDIO
          </div>
          <h1 class="mb-6">
            Websites & <Brace>Automation Systems</Brace> That Help Your Business Grow Faster.
          </h1>
          <p class="text-lg md:text-xl text-gray-700 mb-10 leading-relaxed max-w-xl">
            Get your business website in <strong>48 hours</strong>. We are a global no-code automation agency helping businesses scale with AI workflows and high-converting websites.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a 
              href="/contact"
              class="bg-[#FF0000] text-white px-8 py-4 font-bold text-lg hover:bg-black transition-all flex items-center justify-center group"
            >
              Get Your Website Now <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a 
              href="https://wa.me/919810141789"
              target="_blank"
              class="border-2 border-[#25D366] text-black px-8 py-4 font-bold text-lg hover:bg-[#25D366] hover:text-white transition-all flex items-center justify-center"
            >
              WhatsApp Us
            </a>
          </div>
          <div class="flex items-center gap-4 text-sm text-gray-500 font-mono">
            <span class="flex items-center gap-1"><span class="text-[#FF0000]">●</span> Trusted by 100+ businesses</span>
            <span class="flex items-center gap-1"><span class="text-[#FF0000]">●</span> Fast 48h delivery</span>
          </div>
        </div>
        
        <div class="lg:w-1/2 w-full">
          <Terminal title="init_global.json" className="transform rotate-1 lg:rotate-3 hover:rotate-0 transition-transform duration-500">
            <CodeSnippet code={heroCode} />
          </Terminal>
        </div>
      </div>
    </section>

    {/* Trust Bar */}
    <section class="py-12 border-y border-gray-100 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-center text-xs font-mono text-gray-600 mb-10 uppercase tracking-widest">Integrating your favorite tools</p>
        <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-8 md:gap-x-12">
          {integrationPartners.map(partner => (
            <a 
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300 group"
            >
              <img 
                src={partner.logo} 
                alt={`${partner.name} logo`} 
                width="120" 
                height="32" 
                loading="lazy"
                decoding="async"
                class="h-6 md:h-8 w-auto object-contain" 
              />
              <span class="text-sm font-bold font-mono text-gray-900 group-hover:text-black">{partner.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* Stats Section */}
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold mb-2">
                <Brace>{stat.value}</Brace>
              </div>
              <div class="text-sm font-mono text-gray-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Services Grid */}
    <section class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
          <div>
            <h2 class="mb-4">Expert <Brace>Website Development</Brace> & AI Automation</h2>
            <p class="text-gray-700 max-w-lg mb-0">Everything you need to automate, scale, and thrive in the modern digital economy with powerful AI workflow automation.</p>
            <div class="mt-4 text-sm font-medium text-gray-500">
              <p class="mb-0">How does AI automation save time for businesses? We implement custom workflows that handle repetitive tasks 24/7.</p>
            </div>
          </div>
          <a 
              href="/services"
              class="text-[#FF0000] font-bold hover:underline"
          >
            View all services →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {SERVICES.map((s, idx) => (
              <div class={`bg-white p-8 border border-gray-100 hover:border-[#FF0000] hover:shadow-xl transition-all group ${idx >= 6 ? 'md:hidden lg:block' : ''}`}>
                <div class="text-2xl font-mono text-[#FF0000] mb-6 group-hover:scale-110 transition-transform origin-left">{s.icon}</div>
                <h3 class="mb-3">{s.title}</h3>
                <p class="text-gray-700 text-sm mb-6 leading-relaxed">{s.description}</p>
              <a 
                  href={`/services/${s.id}`}
                  class="text-xs font-bold font-mono uppercase tracking-widest text-gray-500 group-hover:text-[#FF0000] transition-colors"
              >
                Learn more →
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Who We Help */}
    <section class="py-24 bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="mb-4">Automation Systems for <Brace>Small Businesses</Brace></h2>
          <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-0">We build custom website development and AI automation for small business and specific industries in India.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {audiences.map((audience) => (
            <div class="bg-gray-50 p-8 border border-gray-100 hover:border-black transition-colors group">
              <h3 class="mb-3 group-hover:text-[#FF0000] transition-colors">{audience.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-0">{audience.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* How It Works */}
    <section class="py-24 bg-gray-50 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="mb-16 text-center">SEO & <Brace>Growth Services</Brace> for Local Authority</h2>
        
        <div class="relative">
          {/* Connecting line */}
          <div class="absolute top-1/2 left-0 w-full h-0.5 bg-gray-100 hidden md:block"></div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative z-10">
            {processSteps.map((item) => (
              <div class="bg-white border border-gray-100 p-8 text-center relative hover:translate-y-[-8px] transition-transform duration-300">
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#FF0000] text-white font-mono px-3 py-1 text-xs">
                  STEP {item.step}
                </div>
                <h3 class="text-2xl font-bold mb-4 mt-4">
                  <Brace class="text-lg">{item.title}</Brace>
                </h3>
                <p class="text-gray-700 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Social Proof */}
    <section class="py-24 bg-white text-black overflow-hidden relative border-y border-gray-100">
      <div class="max-w-7xl mx-auto px-6 mb-16 relative z-10 text-center">
        <h2 class="text-black mb-4">Trusted by <Brace>100+ Businesses</Brace></h2>
        <p class="text-gray-400 text-sm font-mono uppercase tracking-widest">Real results from global partners</p>
      </div>
      
      <TestimonialCarousel client:visible testimonials={testimonials} />
      
      <div class="max-w-7xl mx-auto px-6 mt-16 relative z-10">
        <div class="pt-16 border-t border-gray-100">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
              <div class="text-2xl md:text-3xl font-bold text-black mb-1">98%</div>
              <div class="text-[10px] font-mono text-gray-400 uppercase tracking-widest">Retention</div>
            </div>
            <div>
              <div class="text-2xl md:text-3xl font-bold text-black mb-1">150+</div>
              <div class="text-[10px] font-mono text-gray-400 uppercase tracking-widest">Deployments</div>
            </div>
            <div>
              <div class="text-2xl md:text-3xl font-bold text-black mb-1">24/7</div>
              <div class="text-[10px] font-mono text-gray-400 uppercase tracking-widest">Monitoring</div>
            </div>
            <div>
              <div class="text-2xl md:text-3xl font-bold text-black mb-1">10M+</div>
              <div class="text-[10px] font-mono text-gray-400 uppercase tracking-widest">Leads</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <FAQ faqs={faqsData} />

    {/* Newsletter CTA */}
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-6">
          <Brace>Subscribe</Brace> to Weekly Automation Tips
        </h2>
        <p class="text-gray-700 mb-10">Join 5,000+ forward-thinking business owners getting expert tips every Tuesday.</p>
        
        <NewsletterForm client:visible />
      </div>
    </section>
  </div>
</Layout>

