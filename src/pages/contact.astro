---
import Layout from '../layouts/Layout.astro';
import { Contact } from '../react-pages/Contact';

const title = "Contact NoobDev | Web Development & Automation Agency Noida";
const description = "Get in touch with NoobDev Technologies in Noida. We build high-performance websites and AI automation systems to help your business grow faster.";
const keywords = "contact NoobDev, web development agency Noida, automation agency Greater Noida, hire web developer India";
---
<Layout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumb={[{ name: "Contact Us", item: "https://noobdev.tech/contact" }]}
>
  <Contact client:visible />
</Layout>
