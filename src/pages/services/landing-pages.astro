---
import Layout from '../../layouts/Layout.astro';
import Brace from '../../components/Brace.astro';

const title = "Fast Landing Pages Services in Noida & Greater Noida | NoobDev";
const description = "NoobDev offers premium Fast Landing Pages services in Noida and Greater Noida. Stop wasting ad spend on slow pages. We build lightning-fast, mobile-optimized landing pages that turn clicks into customers.";
const keywords = "Fast Landing Pages agency Noida, Fast Landing Pages Greater Noida, Fast Landing Pages India, affordable Fast Landing Pages Noida";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fast Landing Pages",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Noob{Dev} Technologies",
    "areaServed": ["Noida", "Greater Noida", "Delhi NCR", "India"]
  },
  "description": description
};
---
<Layout title={title} description={description} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  {/* Hero Section */}
  <section class="pt-32 pb-20 md:pt-40 md:pb-24 bg-white border-b border-gray-100">
    <div class="container-custom text-center max-w-4xl mx-auto">
      <div class="inline-block bg-gray-100 px-3 py-1 text-[10px] font-mono mb-6 border-l-2 border-[#FF0000] uppercase tracking-widest">
        Core Service
      </div>
      <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">
        High-Converting Landing Pages Built for <Brace>Speed</Brace>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 mb-10 leading-relaxed max-w-2xl mx-auto">
        Stop wasting ad spend on slow pages. We build lightning-fast, mobile-optimized landing pages that turn clicks into customers.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/contact" class="bg-black text-white px-8 py-4 font-bold text-sm hover:bg-[#FF0000] transition-all uppercase tracking-widest rounded-lg shadow-lg shadow-black/10">
          Book a Call
        </a>
        <a href="#process" class="bg-gray-50 text-black border border-gray-200 px-8 py-4 font-bold text-sm hover:border-black transition-all uppercase tracking-widest rounded-lg">
          View Process
        </a>
      </div>
    </div>
  </section>

  {/* Problem Section */}
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">The <Brace>Challenge</Brace></h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Your ads are working, but your landing page is killing the conversion.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center mb-6">
            <span class="text-[#FF0000] font-bold text-xl">!</span>
          </div>
          <h3 class="text-lg font-bold mb-3">Slow Load Times</h3>
          <p class="text-gray-600 text-sm leading-relaxed">A 1-second delay reduces conversions by 7%. Slow pages waste your ad budget.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center mb-6">
            <span class="text-[#FF0000] font-bold text-xl">!</span>
          </div>
          <h3 class="text-lg font-bold mb-3">Poor Mobile Experience</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Over 60% of traffic is mobile. If your page isn't flawless on phones, you lose.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center mb-6">
            <span class="text-[#FF0000] font-bold text-xl">!</span>
          </div>
          <h3 class="text-lg font-bold mb-3">Confusing UX</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Unclear messaging and hidden CTAs confuse visitors and cause them to bounce.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Solution Section */}
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">The <Brace>NoobDev</Brace> Solution</h2>
        <p class="text-gray-600 text-lg leading-relaxed">
          We engineer landing pages specifically for paid traffic. Using modern frameworks, we ensure 90+ PageSpeed scores, crystal-clear copywriting, and frictionless conversion paths.
        </p>
      </div>
      
      {/* Features */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <div class="flex gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <span class="text-[#FF0000] font-mono text-sm mt-1">01.</span>
          <div>
            <h4 class="font-bold text-black mb-2">Lightning Fast</h4>
            <p class="text-gray-600 text-sm">Optimized assets and modern code for instant loading.</p>
          </div>
        </div>
        <div class="flex gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <span class="text-[#FF0000] font-mono text-sm mt-1">02.</span>
          <div>
            <h4 class="font-bold text-black mb-2">Conversion-Focused UI</h4>
            <p class="text-gray-600 text-sm">Designed based on proven psychological triggers and UX principles.</p>
          </div>
        </div>
        <div class="flex gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <span class="text-[#FF0000] font-mono text-sm mt-1">03.</span>
          <div>
            <h4 class="font-bold text-black mb-2">A/B Testing Ready</h4>
            <p class="text-gray-600 text-sm">Built to easily test headlines, offers, and layouts.</p>
          </div>
        </div>
        <div class="flex gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <span class="text-[#FF0000] font-mono text-sm mt-1">04.</span>
          <div>
            <h4 class="font-bold text-black mb-2">CRM Integration</h4>
            <p class="text-gray-600 text-sm">Leads flow instantly into your sales pipeline.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Process Section */}
  <section id="process" class="section-padding bg-gray-50 border-y border-gray-100">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our <Brace>Process</Brace></h2>
        <p class="text-gray-600 max-w-2xl mx-auto">A streamlined, transparent approach to taking your project from concept to launch.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-px bg-gray-200 -translate-y-1/2 z-0"></div>
        {[
          { step: "01", title: "Discovery", desc: "We analyze your business goals and current bottlenecks." },
          { step: "02", title: "Strategy", desc: "Crafting a tailored plan and architecture for your needs." },
          { step: "03", title: "Execution", desc: "Building and integrating the solution with precision." },
          { step: "04", title: "Launch", desc: "Testing, deployment, and ongoing optimization." }
        ].map(item => (
          <div class="relative z-10 bg-white border border-gray-100 p-8 rounded-2xl shadow-sm hover:border-[#FF0000]/50 transition-colors">
            <div class="text-[#FF0000] font-mono text-xl mb-4">{item.step}.</div>
            <h3 class="text-black text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Results / Benefits */}
  <section class="section-padding bg-white border-b border-gray-100">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        
        <div class="p-6">
          <div class="text-4xl md:text-5xl font-bold text-black mb-2"><Brace>90+</Brace></div>
          <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">PageSpeed Score</div>
        </div>
        <div class="p-6">
          <div class="text-4xl md:text-5xl font-bold text-black mb-2"><Brace>2x</Brace></div>
          <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Conversion Rate</div>
        </div>
        <div class="p-6">
          <div class="text-4xl md:text-5xl font-bold text-black mb-2"><Brace>&lt;2s</Brace></div>
          <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Load Time</div>
        </div>
        <div class="p-6">
          <div class="text-4xl md:text-5xl font-bold text-black mb-2"><Brace>100%</Brace></div>
          <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Mobile Ready</div>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-24 bg-gray-50 border-t border-gray-100 text-center">
    <div class="container-custom max-w-3xl">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Let's build something that <Brace>grows your business</Brace></h2>
      <p class="text-xl text-gray-600 mb-10">Stop losing time and customers. Upgrade to a high-performance digital engine today.</p>
      <a href="/contact" class="inline-block bg-[#FF0000] text-white px-10 py-5 font-bold text-sm hover:bg-black transition-all uppercase tracking-widest rounded-lg shadow-xl shadow-red-500/20">
        Book a Strategy Call →
      </a>
    </div>
  </section>
</Layout>
