---
import Layout from '../../layouts/Layout.astro';
import Brace from '../../components/Brace.astro';
import Terminal from '../../components/Terminal.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';
import { SERVICES } from '../../constants';
import { ServicesExplorer } from '../../react-components/ServicesExplorer';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    question: "How much does custom business automation cost?",
    answer: "Pricing depends entirely on the complexity of the workflow. Simple Zapier integrations start around $499, while complex, multi-platform AI automation systems can range from $2,000 to $10,000+. We always provide a clear, fixed-price quote after our initial discovery call."
  },
  {
    question: "Do I need to know how to code to manage these systems?",
    answer: "Not at all. Our entire philosophy is built around 'no-code' and 'low-code' handoffs. We build the complex architecture, but we deliver it with user-friendly dashboards and comprehensive video training so your team can manage day-to-day operations easily."
  },
  {
    question: "What tools do you use for AI and automation?",
    answer: "We are tool-agnostic, meaning we use the best tool for your specific problem. Our stack frequently includes Make.com, Zapier, n8n, OpenAI (ChatGPT), Anthropic (Claude), Airtable, and custom Node.js scripts when APIs require heavy lifting."
  },
  {
    question: "How long does it take to build a custom website or CRM?",
    answer: "High-converting landing pages can be deployed in 48-72 hours. Full custom web applications (React/Next.js) or comprehensive CRM setups (HubSpot/Salesforce) typically take between 4 to 8 weeks, depending on data migration needs and custom feature requirements."
  },
  {
    question: "Will these automations break if an app updates?",
    answer: "APIs do change, which is why we build robust error handling into our workflows. If a connection drops, the system alerts us immediately. We also offer ongoing monthly maintenance retainers to ensure your automations run smoothly 24/7 without you having to worry about technical updates."
  },
  {
    question: "Do you offer ongoing support after launch?",
    answer: "Yes. Every project includes a 30-day warranty period for bug fixes and minor adjustments. After that, we offer dedicated support and growth retainers for clients who want continuous optimization, SEO management, and new feature development."
  },
  {
    question: "Can you integrate with my existing legacy software?",
    answer: "Yes, we specialize in bridging the gap between modern AI tools and legacy systems. If your software has an API, we can connect it. If not, we can often use custom bots or RPA (Robotic Process Automation) to sync data automatically."
  },
  {
    question: "What is the typical ROI for AI automation?",
    answer: "Most of our clients see a full return on investment within 3 to 6 months. By eliminating manual data entry and reducing human error, businesses can often reallocate 20-40% of their staff's time to higher-value strategic tasks."
  },
  {
    question: "Is my data secure with AI and no-code tools?",
    answer: "Security is our top priority. We use enterprise-grade tools like Make.com and Zapier which comply with SOC2 and GDPR standards. We also implement strict data handling protocols and can build 'human-in-the-loop' systems for sensitive operations."
  },
  {
    question: "How do we get started with Noob{Dev}?",
    answer: "The process starts with a free discovery call where we audit your current workflows. Once we identify the biggest bottlenecks, we provide a detailed proposal and roadmap. Most projects kick off within 48 hours of approval."
  }
];
const title = "Our Services | Web Development & Automation Agency Noida";
const description = "Explore NoobDev's services: AI Automation, Custom Websites, SEO, GEO, CRM Setup, and more. We help businesses in Noida and globally scale faster.";
const keywords = "web development services Noida, AI automation services Greater Noida, SEO services India, custom websites Noida";

---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumb={[{ name: "Services", item: "https://noobdev.tech/services" }]}
  faqs={faqs}
>
  <div class="page-transition section-padding">
    <div class="container-custom">
      <div class="mb-24 text-center">
        <h1 class="mb-6">Our <Brace>Expertise</Brace>: AI Automation & Web Development</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">From AI workflows to custom web development, Noob{`{Dev}`} Technologies provides the technical foundation your business needs to scale without the friction of traditional coding. We serve clients globally.</p>
      </div>

      {/* Services Explorer */}
      <div class="mb-32">
        <ServicesExplorer client:visible services={SERVICES} />
      </div>

      {/* FAQ Section */}
      <div class="mt-32">
        <FAQ faqs={faqs} />
      </div>

    </div>
  </div>
</Layout>

