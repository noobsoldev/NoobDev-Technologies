---
import Layout from '../layouts/Layout.astro';
import Brace from '../components/Brace.astro';
import Terminal from '../components/Terminal.astro';
import CodeSnippet from '../components/CodeSnippet.astro';
import locations from '../data/locations.json';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { city: loc.slug },
    props: { city: loc.city },
  }));
}

const { city } = Astro.props;

const cityConfig = `{
  "service": "Web Development",
  "status": "active",
  "features": [
    "Hyperlocal SEO",
    "Fast Delivery (48h)",
    "AI Automation",
    "No-Code Efficiency"
  ]
}`;

const title = `Web Development Agency in ${city} | NoobDev Technologies`;
const description = `Expert web development and no-code automation agency serving ${city}. We build high-converting websites for local businesses and automate workflows using AI.`;
const keywords = `web development agency ${city}, automation agency ${city}, website design ${city}`;

const faqs = [
  {
    question: `How long does it take to build a website?`,
    answer: "Our standard landing pages are delivered in 48-72 hours. More complex custom websites typically take 4-12 weeks depending on the requirements."
  },
  {
    question: `Do you offer local SEO services?`,
    answer: `Yes, we specialize in local SEO and GEO (Generative Engine Optimization) to ensure your business ranks at the top of search results and AI recommendations.`
  },
  {
    question: "What industries do you serve?",
    answer: "We work with a wide range of industries including healthcare clinics, retail stores, real estate agencies, and digital startups."
  }
];
---

<Layout title={title} description={description} keywords={keywords} faqs={faqs}>
  <div class="page-transition pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-20 text-center">
        <h1 class="mb-6">
          Premium <Brace>Web Development</Brace> Agency
        </h1>
        <p class="text-lg md:text-xl text-gray-700 max-w-3xl mx-auto mb-0">
          Transform your business with high-performance digital assets. We are the leading web design and automation experts serving your area.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-32">
        <div class="prose prose-lg max-w-none text-gray-700">
          <h2 class="text-black mb-6">Dominate Your Local Market</h2>
          <p>
            In today's competitive landscape, having a simple website isn't enough. Businesses need a digital presence that is fast, secure, and optimized for conversions. At Noob{`{Dev}`} Technologies, we specialize in building websites that don't just look good: they work for you 24/7.
          </p>
          <p>
            Whether you run a <strong>salon</strong>, a <strong>coaching center</strong>, or an <strong>RO repair service</strong>, our team understands the local market dynamics. We implement advanced local SEO strategies to ensure that when customers search for services, your business is the first one they see.
          </p>
          <p>
            Our "Get Your Website in 48 Hours" program is designed specifically for small businesses that need to move fast. We eliminate the technical hurdles by using modern no-code tools and AI-driven workflows, allowing you to focus on what you do best: running your business.
          </p>
        </div>
        <div class="w-full">
          <Terminal title={`init_config.json`} className="transform rotate-1 lg:rotate-3 hover:rotate-0 transition-transform duration-500">
            <CodeSnippet code={cityConfig} />
          </Terminal>
          <div class="mt-8 text-center lg:text-left">
            <a href="/contact" class="inline-block bg-[#FF0000] text-white px-8 py-4 font-bold rounded-lg hover:bg-black transition-all">
              Get a Free Quote
            </a>
          </div>
        </div>
      </div>

      <div class="mb-32">
        <h2 class="mb-12 text-center">Tailored Solutions for Local Businesses</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-8 border border-gray-100 shadow-sm">
            <h3 class="mb-4">Retail & Showrooms</h3>
            <p class="text-gray-600 text-sm mb-0">Digital showrooms for jewelers and boutiques to drive foot traffic and online inquiries.</p>
          </div>
          <div class="bg-white p-8 border border-gray-100 shadow-sm">
            <h3 class="mb-4">Service Providers</h3>
            <p class="text-gray-600 text-sm mb-0">Booking systems and lead generation for RO repair, mehandi artists, and home services.</p>
          </div>
          <div class="bg-white p-8 border border-gray-100 shadow-sm">
            <h3 class="mb-4">Health & Wellness</h3>
            <p class="text-gray-600 text-sm mb-0">Patient management and appointment scheduling for clinics and gyms.</p>
          </div>
        </div>
      </div>

      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map(faq => (
            <div class="border-b border-gray-200 pb-6">
              <h3 class="text-xl font-bold mb-3">{faq.question}</h3>
              <p class="text-gray-600">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-32 text-center hidden">
        <p class="text-gray-500 mb-4">Also serving nearby areas:</p>
        <div class="flex flex-wrap justify-center gap-4">
          {locations.filter(l => l.city !== city).map(l => (
            <a href={`/${l.slug}-web-development`} class="text-[#FF0000] hover:underline font-medium">
              Web Development {l.city}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
